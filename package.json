{
  "name": "casino-proto",
  "version": "1.0.0",
  "description": "NeonBet Casino — Virtual-currency-only online casino prototype with provably-fair gaming",
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "main": "backend/server.js",
  "scripts": {
    "setup": "npm ci && npm run migrate && npm run seed",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "node --watch backend/server.js",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "preview": "cd frontend && npm run preview",
    "start": "node backend/server.js",
    "test": "jest --coverage --forceExit",
    "test:watch": "jest --watch",
    "test:backend": "jest backend/tests --forceExit",
    "migrate": "node backend/migrations/runner.js",
    "seed": "node backend/migrations/seed.js",
    "lint": "eslint backend/ --max-warnings 0",
    "lint:fix": "eslint backend/ --fix",
    "audit": "npm audit --audit-level=high"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "better-sqlite3": "^9.2.2",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.1.2",
    "dotenv": "^16.4.1",
    "cors": "^2.8.5",
    "body-parser": "^1.20.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "concurrently": "^8.2.2",
    "eslint": "^8.54.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "backend/**/*.js",
      "!backend/migrations/**",
      "!backend/tests/**",
      "!backend/server.js"
    ],
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/tests/**/*.test.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 50,
        "lines": 50,
        "statements": 50
      }
    }
  }
}
