# ─────────────────────────────────────────────────────────────────────────────
# NeonBet Casino — Environment Variables
# Copy this to .env and fill in your values. .env is in .gitignore (never commit secrets!)
# ─────────────────────────────────────────────────────────────────────────────

# ── Server & Environment ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
JWT_SECRET=your-very-secret-jwt-key-here-min-32-chars

# ── Database ─────────────────────────────────────────────────────────────────
DB_PATH=./data/casino.sqlite

# ── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Games: Jackpot Configuration ─────────────────────────────────────────────
JACKPOT_SEED_AMOUNT=10000
JACKPOT_CONTRIBUTION_RATE=0.005

# ── Security: Bcrypt Rounds ──────────────────────────────────────────────────
# Number of salt rounds for bcrypt (higher = slower but more secure)
# Use 10 for production, 4 for tests (speed)
BCRYPT_ROUNDS=10

# ── Logging (optional) ───────────────────────────────────────────────────────
# Set to 'true' to enable verbose Socket.io event logging
SOCKET_DEBUG=false
LOG_LEVEL=info

# ── CORS (for production) ───────────────────────────��────────────────────────
# If deploying frontend separately, set to the frontend domain
# CORS_ORIGIN=https://yourdomain.com

